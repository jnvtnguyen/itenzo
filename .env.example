# COPY THIS FILE TO .env AND FILL IN YOUR REAL VALUE.
#
# PUBLIC MAPBOX TOKEN (pk.*). Safe to embed in the app bundle — EXPO_PUBLIC_*
# vars are compiled into the JS. Drives the web map tiles and the Mapbox
# Search Box place autocomplete. Give it the default public scopes.
EXPO_PUBLIC_MAPBOX_TOKEN=pk.your_public_token_here

# NOTE: the SECRET download token (sk.*) does NOT go in any .env file — it is
# a build-time credential set as an EAS environment variable named
# RNMAPBOX_MAPS_DOWNLOAD_TOKEN. See MAPS_SETUP.md.

# OPENROUTER KEY — POWERS EVERY AI SURFACE (gap suggestions, the ask bar,
# "Plan it for me" trip drafting). Without it the app is fully manual.
# Get one at https://openrouter.ai/keys. NOTE: EXPO_PUBLIC_* vars compile into
# the JS bundle — fine for a personal dev build, but a shipped app should move
# LLM calls behind a backend proxy.
EXPO_PUBLIC_OPENROUTER_KEY=sk-or-your_key_here

# Optional: which model the assistant uses (any OpenRouter model id).
# EXPO_PUBLIC_OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
